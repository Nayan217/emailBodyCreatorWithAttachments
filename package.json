{
  "name": "mime-email-builder",
  "version": "1.0.0",
  "description": "Server-side MIME email builder using EJS + Node.js + React",
  "main": "server.ts",
  "scripts": {
    "start":      "ts-node server.ts",
    "dev":        "nodemon --exec ts-node server.ts",
    "build":      "cd client && npm install && npm run build",
    "dev:client": "cd client && npm run dev",
    "setup":      "npm install && npm run build"
  },
  "dependencies": {
    "ejs":     "^3.1.10",
    "express": "^4.18.2",
    "multer":  "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/ejs":        "^3.1.5",
    "@types/express":    "^4.17.21",
    "@types/multer":     "^1.4.11",
    "@types/node":       "^20.14.0",
    "nodemon":           "^3.0.2",
    "ts-node":           "^10.9.2",
    "typescript":        "^5.5.3"
  }
}
