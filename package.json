{
  "name": "mime-email-builder",
  "version": "1.0.0",
  "description": "Server-side MIME email builder using EJS + Node.js + React",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "build":     "cd client && npm install && npm run build",
    "dev:client":"cd client && npm run dev",
    "setup":     "npm install && npm run build"
  },
  "dependencies": {
    "ejs":    "^3.1.10",
    "express":"^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon":"^3.0.2"
  }
}
